<div style="width:800px; height:470px; background:#000; color:#fff; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; padding:10px; display:flex; box-sizing:border-box; position:relative;">

  <div style="position:absolute; top:10px; right:16px; background:#000; color:#ff0000; font-size:11px; font-weight:900; letter-spacing:0.2em; text-transform:uppercase; z-index:10;">
    {{ updated_at }}
  </div>

  {% assign active_sonos = sonos | where: "state", "playing" %}
  {% assign is_playing = false %}
  {% if active_sonos.size > 0 %}{% assign is_playing = true %}{% endif %}
  {% assign last_active = sonos | where_exp: "s", "s.state == 'playing' or s.state == 'paused'" | first %}
  {% if last_active and last_active.state == 'playing' %}{% assign is_playing = true %}{% endif %}

  {% if is_playing %}
  <div style="display:grid; grid-template-columns:1fr 1fr; grid-template-rows:1fr 1fr; gap:8px; width:100%; height:100%;">
  {% else %}
  <div style="display:grid; grid-template-columns:1fr 1fr; grid-template-rows:1fr 1fr; gap:8px; width:100%; height:100%;">
  {% endif %}

    {% comment %} FAMILY CARD — black bg, colored text {% endcomment %}
    <div style="background:#000; color:#fff; border:2px solid #fff; border-radius:20px; padding:14px 16px; display:flex; flex-direction:column; justify-content:space-between;">
      <div style="font-size:11px; line-height:1; letter-spacing:0.2em; text-transform:uppercase; font-weight:900; color:#ff0000;">Family</div>
      <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:2px;">
        {% for person in people %}
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div style="font-size:22px; font-weight:900; letter-spacing:-0.02em; color:#fff;">{{ person.name }}</div>
          <div style="font-size:12px; font-weight:900; text-transform:uppercase; letter-spacing:0.08em; color:{% if person.state == 'home' %}#00ff00{% else %}#ff0000{% endif %}; border:2px solid {% if person.state == 'home' %}#00ff00{% else %}#ff0000{% endif %}; padding:3px 10px; border-radius:12px;">
            {{ person.state }}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

    {% comment %} WEATHER CARD — blue bg {% endcomment %}
    <div style="background:#0000ff; color:#fff; border-radius:20px; padding:14px 16px; display:flex; flex-direction:column; justify-content:space-between; position:relative; overflow:hidden;">
      <div style="font-size:11px; line-height:1; letter-spacing:0.2em; text-transform:uppercase; font-weight:900; color:#ffff00;">Weather</div>

      <div style="position:absolute; top:-10px; right:-10px; opacity:0.12; pointer-events:none;">
        <svg width="160" height="160" viewBox="0 0 24 24" fill="#fff">
          <path d="M6.76 4.84l-1.8-1.79-1.41 1.41 1.79 1.79zM4 10.5H1v2h3zm9-9.95h-2V3.5h2zm7.45 3.91l-1.41-1.41-1.79 1.79 1.41 1.41zm-3.21 13.7l1.79 1.8 1.41-1.41-1.8-1.79zM20 10.5v2h3v-2zm-8-5c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm-1 16.95h2V19.5h-2zm-7.45-3.91l1.41 1.41 1.79-1.8-1.41-1.41z"/>
        </svg>
      </div>

      <div style="display:flex; flex-direction:column; justify-content:flex-end; flex:1; padding-bottom:2px; z-index:2;">
        {% if weather and weather.temperature != blank %}
        <div style="display:flex; justify-content:space-between; align-items:flex-end;">
          <div style="display:flex; flex-direction:column;">
            <div style="font-size:72px; line-height:0.85; font-weight:900; letter-spacing:-0.05em; color:#fff;">{{ weather.temperature | round }}<span style="font-size:32px;">°</span></div>
            <div style="font-size:22px; font-weight:900; text-transform:capitalize; letter-spacing:-0.02em; margin-top:4px; color:#ffff00;">{{ weather.condition | replace: "-", " " }}</div>
          </div>
          <div style="display:flex; flex-direction:column; gap:4px; align-items:flex-end; padding-bottom:4px;">
            {% if weather.humidity %}
            <div style="font-size:13px; font-weight:800; letter-spacing:0.02em; color:#fff;">{{ weather.humidity }}% hum</div>
            {% endif %}
            {% if weather.wind_speed %}
            <div style="font-size:13px; font-weight:800; letter-spacing:0.02em; color:#fff;">{{ weather.wind_speed | round }} km/h</div>
            {% endif %}
          </div>
        </div>
        {% endif %}
      </div>
    </div>

    {% comment %} MUSIC CARD — red bg, only when active {% endcomment %}
    {% if last_active %}
    <div style="background:#ff0000; color:#fff; border-radius:20px; padding:14px 16px; display:flex; flex-direction:column; justify-content:space-between; overflow:hidden; position:relative;">
      <div style="font-size:11px; line-height:1; letter-spacing:0.2em; text-transform:uppercase; font-weight:900; opacity:0.9; position:relative; z-index:2;">{% if is_playing %}Now Playing{% else %}Last Played{% endif %} · {{ last_active.room }}</div>

      <div style="display:flex; justify-content:space-between; align-items:flex-end; position:relative; z-index:2;">
        <div style="display:flex; flex-direction:column; max-width:66%;">
          {% if last_active.title and last_active.title != blank %}
          <div style="font-size:22px; font-weight:900; letter-spacing:-0.02em; line-height:1.05; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; color:#fff;">{{ last_active.title }}</div>
          <div style="font-size:15px; font-weight:800; opacity:0.85; margin-top:4px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:#ffff00;">{{ last_active.artist }}</div>
          {% else %}
          <div style="font-size:22px; font-weight:900; letter-spacing:-0.02em; opacity:0.6; color:#fff;">Idle</div>
          {% endif %}
        </div>
        {% if last_active.picture and last_active.picture != blank %}
        <div style="width:64px; height:64px; border-radius:10px; overflow:hidden; border:2px solid #000; flex-shrink:0; background:#000;">
          <img src="{{ last_active.picture }}" style="width:100%; height:100%; object-fit:cover;" />
        </div>
        {% else %}
        <div style="width:64px; height:64px; border-radius:10px; overflow:hidden; border:2px solid #000; flex-shrink:0; background:#000; display:flex; align-items:center; justify-content:center;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ffff00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {% comment %} HOME STATUS CARD — always fills remaining space {% endcomment %}
    {% if is_playing %}
    <div style="background:#000; color:#fff; border:2px solid #ffff00; border-radius:20px; padding:14px 16px; display:flex; flex-direction:column; justify-content:space-between; grid-column: span 1;">
    {% else %}
    <div style="background:#000; color:#fff; border:2px solid #ffff00; border-radius:20px; padding:14px 16px; display:flex; flex-direction:column; justify-content:space-between; grid-column: span 2;">
    {% endif %}
      <div style="font-size:11px; line-height:1; letter-spacing:0.2em; text-transform:uppercase; font-weight:900; color:#ffff00;">Home Status</div>
      <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:2px;">
        {% if home and home.door_locked != blank %}

        {% if is_playing %}
        {% assign status_cols = '1fr 1fr' %}
        {% else %}
        {% assign status_cols = '1fr 1fr 1fr 1fr' %}
        {% endif %}

        {% if is_playing %}
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
        {% else %}
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:10px;">
        {% endif %}

          {% comment %} Door {% endcomment %}
          <div style="display:flex; flex-direction:column; gap:6px;">
            <div style="display:flex; align-items:center; gap:6px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="{% if home.door_locked %}#00ff00{% else %}#ff0000{% endif %}">
                <path d="M12 2C9.24 2 7 4.24 7 7V10H6C4.9 10 4 12 4 12V20C4 21.1 4.9 22 6 22H18C19.1 22 20 21.1 20 20V12C20 10.9 19.1 10 18 10H17V7C17 4.24 14.76 2 12 2ZM12 4C13.66 4 15 5.34 15 7V10H9V7C9 5.34 10.34 4 12 4Z"/>
              </svg>
              <div style="font-size:{% if is_playing %}12px{% else %}15px{% endif %}; font-weight:900; color:#fff;">Door</div>
            </div>
            <div style="font-size:{% if is_playing %}16px{% else %}22px{% endif %}; font-weight:900; color:{% if home.door_locked %}#00ff00{% else %}#ff0000{% endif %};">{% if home.door_locked %}Locked{% else %}Open{% endif %}</div>
          </div>

          {% comment %} Laundry {% endcomment %}
          <div style="display:flex; flex-direction:column; gap:6px;">
            <div style="display:flex; align-items:center; gap:6px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="{% if home.washer_running %}#ff8800{% else %}#00ff00{% endif %}">
                <path d="M19 4H5C3.9 4 3 4.9 3 6V18C3 19.1 3.9 20 5 20H19C20.1 20 21 19.1 21 18V6C21 4.9 20.1 4 19 4ZM12 17C9.79 17 8 15.21 8 13C8 10.79 9.79 9 12 9C14.21 9 16 10.79 16 13C16 15.21 14.21 17 12 17ZM7 7H5V5H7V7Z"/>
              </svg>
              <div style="font-size:{% if is_playing %}12px{% else %}15px{% endif %}; font-weight:900; color:#fff;">Laundry</div>
            </div>
            <div style="font-size:{% if is_playing %}16px{% else %}22px{% endif %}; font-weight:900; color:{% if home.washer_running %}#ff8800{% else %}#00ff00{% endif %};">{% if home.washer_running %}Running{% else %}Idle{% endif %}</div>
          </div>

          {% comment %} Blinds {% endcomment %}
          <div style="display:flex; flex-direction:column; gap:6px;">
            <div style="display:flex; align-items:center; gap:6px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#00bfff">
                <path d="M20 19V3H4V19H2V21H22V19H20ZM14 9H10V11H14V9ZM14 13H10V15H14V13Z"/>
              </svg>
              <div style="font-size:{% if is_playing %}12px{% else %}15px{% endif %}; font-weight:900; color:#fff;">Blinds</div>
            </div>
            <div style="font-size:{% if is_playing %}16px{% else %}22px{% endif %}; font-weight:900; color:{% if home.blind_position == 'unavailable' %}#ff0000{% else %}#00bfff{% endif %};">{% if home.blind_position == 'unavailable' %}?{% elsif home.blind_position == "100" %}Open{% else %}Closed{% endif %}</div>
          </div>

          {% comment %} Thermostat {% endcomment %}
          <div style="display:flex; flex-direction:column; gap:6px;">
            <div style="display:flex; align-items:center; gap:6px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#ff0000">
                <path d="M15 13V5C15 3.34 13.66 2 12 2C10.34 2 9 3.34 9 5V13C7.22 14.28 6 16.48 6 19C6 22.31 8.69 25 12 25C15.31 25 18 22.31 18 19C18 16.48 16.78 14.28 15 13ZM12 21C10.9 21 10 20.1 10 19C10 17.9 10.9 17 12 17C13.1 17 14 17.9 14 19C14 20.1 13.1 21 12 21Z"/>
              </svg>
              <div style="font-size:{% if is_playing %}12px{% else %}15px{% endif %}; font-weight:900; color:#fff;">Temp</div>
            </div>
            <div style="font-size:{% if is_playing %}16px{% else %}22px{% endif %}; font-weight:900; color:#ff0000;">{% if home.thermostat_temp %}{{ home.thermostat_temp | round: 1 }}°{% else %}--{% endif %}</div>
          </div>

        </div>

        {% endif %}
      </div>
    </div>

  </div>
</div>
