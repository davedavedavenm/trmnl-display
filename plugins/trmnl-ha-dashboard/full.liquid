{% assign active_sonos = sonos | where: "state", "playing" | first %}
{% if active_sonos == nil %}
  {% assign active_sonos = sonos | where: "state", "paused" | first %}
{% endif %}
{% assign idle_count = sonos | where: "state", "idle" | size %}

<style>
  * { color-profile: srgb; margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Helvetica Neue', 'Segoe UI', Arial, sans-serif; }
  .dash { width: 800px; height: 480px; display: flex; flex-direction: column; background: #000; }
  .row { display: flex; flex: 1; }
  .top-section { flex: 3; display: flex; }
  .bottom-section { flex: 1; display: flex; }
  .panel { display: flex; flex-direction: column; padding: 24px 22px; overflow: hidden; }
  .panel-label { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; opacity: 0.7; }
</style>

<div class="dash">

  <div style="flex: 3.2; display: flex;">

    <!-- WEATHER — Blue panel -->
    <div style="flex: 1.2; background: #0033CC; padding: 28px 26px; display: flex; flex-direction: column; justify-content: center; gap: 6px;">
      <div style="font-size: 10px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: #99BBFF;">Weather</div>
      <div style="font-size: 96px; font-weight: 700; color: #FFFFFF; line-height: 0.85; letter-spacing: -2px; margin-top: 8px;">{{ weather.temperature | round }}<span style="font-size: 36px; vertical-align: super; font-weight: 400;">°</span></div>
      <div style="font-size: 18px; font-weight: 600; color: #FFDD44; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 4px;">{{ weather.condition | replace: "-", " " }}</div>
      <div style="font-size: 13px; font-weight: 500; color: #AACCFF; margin-top: 6px; letter-spacing: 0.5px;">{{ weather.humidity }}% RH · {{ weather.wind_speed | round }} KM/H</div>
    </div>

    <!-- PEOPLE — Red panel -->
    <div style="flex: 1; background: #CC0000; padding: 28px 24px; display: flex; flex-direction: column; justify-content: center;">
      <div style="font-size: 10px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: #FF9999;">People</div>
      <div style="display: flex; flex-direction: column; gap: 14px; margin-top: 14px;">
        {% for person in people %}
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <span style="font-size: 28px; font-weight: 700; color: #FFFFFF; letter-spacing: -0.5px;">{{ person.name }}</span>
          <span style="font-size: 11px; font-weight: 700; letter-spacing: 1.2px; padding: 4px 14px; border-radius: 4px; text-transform: uppercase; background: #000000; color: {% if person.state == 'home' %}#FFDD44{% elsif person.state == 'not_home' %}#FFFFFF{% else %}#999{% endif %};">
            {% if person.state == "home" %}● HOME{% elsif person.state == "not_home" %}AWAY{% else %}?{% endif %}
          </span>
        </div>
        {% endfor %}
      </div>
    </div>

    <!-- HOME — Black panel -->
    <div style="flex: 1; background: #111111; padding: 28px 24px; display: flex; flex-direction: column; justify-content: center; border-left: 1px solid #222;">
      <div style="font-size: 10px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: #888;">Home</div>
      <div style="display: flex; flex-direction: column; gap: 0; margin-top: 8px;">
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #222;">
          <span style="display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 14px;">🔒</span>
            <span style="font-size: 11px; font-weight: 600; color: #888; letter-spacing: 1px; text-transform: uppercase;">Door</span>
          </span>
          <span style="font-size: 14px; font-weight: 700; color: {% if home.door_locked %}#FFDD44{% else %}#FF4444{% endif %};">
            {% if home.door_locked %}LOCKED{% else %}OPEN{% endif %}
          </span>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #222;">
          <span style="display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 14px;">👕</span>
            <span style="font-size: 11px; font-weight: 600; color: #888; letter-spacing: 1px; text-transform: uppercase;">Washer</span>
          </span>
          <span style="font-size: 14px; font-weight: 700; color: {% if home.washer_running %}#FFDD44{% else %}#FFFFFF{% endif %};">
            {% if home.washer_running %}ON{% else %}OFF{% endif %}
          </span>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #222;">
          <span style="display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 14px;">🌡</span>
            <span style="font-size: 11px; font-weight: 600; color: #888; letter-spacing: 1px; text-transform: uppercase;">Thermostat</span>
          </span>
          <span style="font-size: 16px; font-weight: 700; color: #FFFFFF;">
            {% if home.thermostat_temp %}{{ home.thermostat_temp | round: 1 }}°{% else %}--°{% endif %}
          </span>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px 0;">
          <span style="display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 14px;">🪟</span>
            <span style="font-size: 11px; font-weight: 600; color: #888; letter-spacing: 1px; text-transform: uppercase;">Blinds</span>
          </span>
          <span style="font-size: 14px; font-weight: 700; color: #FFFFFF;">
            {% if home.blind_position == "unavailable" or home.blind_position == nil %}--{% else %}{{ home.blind_position }}%{% endif %}
          </span>
        </div>
      </div>
    </div>

  </div>

  <!-- SONOS — Orange strip -->
  <div style="flex: 0.8; background: #DD5500; display: flex; align-items: center; padding: 16px 26px; border-top: 2px solid #FF8833;">
    <div style="display: flex; align-items: center; gap: 16px; width: 100%;">
      <div style="font-size: 22px;">🔊</div>
      <div>
        <div style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #FFCCAA;">Sonos</div>
        {% if active_sonos %}
        <div style="font-size: 18px; font-weight: 700; color: #FFFFFF; margin-top: 2px;">{{ active_sonos.room }} · {{ active_sonos.title }}</div>
        {% else %}
        <div style="font-size: 18px; font-weight: 700; color: #FFFFFF; margin-top: 2px;">No Music Playing</div>
        {% endif %}
      </div>
      <div style="flex: 1;"></div>
      <div style="display: flex; gap: 8px; align-items: center;">
        {% for room in sonos %}
        <div style="display: flex; align-items: center; gap: 4px; padding: 4px 10px; background: rgba(0,0,0,0.2); border-radius: 4px;">
          <span style="display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: {% if room.state == 'playing' %}#FFFFFF{% elsif room.state == 'paused' %}#FFDD88{% else %}#FFFFFF{% endif %}; opacity: {% if room.state == 'idle' %}0.3{% else %}1{% endif %};"></span>
          <span style="font-size: 10px; font-weight: 600; color: #FFFFFF; text-transform: uppercase; letter-spacing: 0.5px;">{{ room.room | truncate: 5, "" }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <!-- Footer bar -->
  <div style="height: 26px; background: #000; display: flex; align-items: center; justify-content: space-between; padding: 0 26px;">
    <span style="font-size: 8px; font-weight: 600; letter-spacing: 1.5px; color: #555; text-transform: uppercase;">7-Color ACeP</span>
    <span style="font-size: 9px; font-weight: 500; color: #666;">{{ updated_at }}</span>
  </div>

</div>
