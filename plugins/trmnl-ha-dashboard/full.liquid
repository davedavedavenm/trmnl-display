{% assign active_sonos = sonos | where: "state", "playing" | first %}
{% if active_sonos == nil %}
  {% assign active_sonos = sonos | where: "state", "paused" | first %}
{% endif %}
{% assign idle_count = sonos | where: "state", "idle" | size %}

<!--
  Spectra 6 hardware palette (pimoroni/inky saturated):
    Black  #000000 | White #a1a4a5 | Ochre #d0be47
    Red    #9c484b | Navy  #3d3b5e | Olive #3a5b46

  Design principle: WHITE base + coloured solid blocks.
  Dark gradients dither to mud on e-ink. White = zero dithering = crisp.
  Colour blocks (solid navy, olive, terracotta) render cleanly and pop.
-->

<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Helvetica Neue','Segoe UI',Arial,sans-serif; }
</style>

<div style="width:800px;height:480px;display:flex;flex-direction:column;background:#ffffff;">

  <!-- HEADER: black bar, ochre timestamp -->
  <div style="height:44px;flex-shrink:0;background:#000000;display:flex;align-items:center;justify-content:space-between;padding:0 22px;">
    <span style="font-size:10px;font-weight:900;letter-spacing:6px;text-transform:uppercase;color:#ffffff;">Home Dashboard</span>
    <span style="font-size:11px;font-weight:700;color:#d0be47;letter-spacing:1px;">{{ updated_at }}</span>
  </div>

  <!-- BODY -->
  <div style="flex:1;display:flex;min-height:0;">

    <!-- WEATHER: solid navy block — white text on navy = great contrast -->
    <div style="width:220px;flex-shrink:0;background:#3d3b5e;display:flex;flex-direction:column;justify-content:space-between;padding:20px 22px;">
      <div>
        <div style="font-size:9px;font-weight:900;letter-spacing:4px;text-transform:uppercase;color:#d0be47;margin-bottom:14px;">Weather</div>
        <div style="font-size:104px;font-weight:900;line-height:0.8;color:#ffffff;letter-spacing:-6px;">{{ weather.temperature | round }}<span style="font-size:38px;font-weight:200;vertical-align:super;letter-spacing:0;opacity:0.8;">°</span></div>
        <div style="font-size:30px;margin-top:18px;line-height:1;">{% assign c = weather.condition | downcase %}{% if c contains "clear" or c contains "sun" %}☀️{% elsif c contains "rain" or c contains "drizzle" or c contains "shower" %}🌧️{% elsif c contains "snow" or c contains "sleet" %}❄️{% elsif c contains "thunder" %}⛈️{% elsif c contains "fog" or c contains "mist" %}🌫️{% elsif c contains "cloud" or c contains "overcast" %}☁️{% else %}🌤️{% endif %}</div>
        <div style="font-size:16px;font-weight:700;color:#ffffff;margin-top:8px;text-transform:capitalize;opacity:0.9;">{{ weather.condition | replace: "-", " " }}</div>
      </div>
      <div style="border-top:1px solid rgba(208,190,71,0.35);padding-top:12px;">
        <div style="font-size:12px;font-weight:600;color:#d0be47;line-height:2.1;">{{ weather.humidity }}% humidity<br>{{ weather.wind_speed | round }} km/h wind</div>
      </div>
    </div>

    <!-- RIGHT: white content area -->
    <div style="flex:1;display:flex;flex-direction:column;background:#ffffff;min-width:0;">

      <!-- PEOPLE: white background, coloured cards -->
      <div style="padding:14px 18px 12px;border-bottom:2px solid #000000;flex-shrink:0;">
        <div style="font-size:8px;font-weight:900;letter-spacing:4px;text-transform:uppercase;color:#3a5b46;margin-bottom:10px;">People</div>
        <div style="display:flex;gap:10px;">
          {% for person in people %}
          <div style="flex:1;display:flex;align-items:center;justify-content:space-between;padding:9px 14px;border:2px solid {% if person.state == 'home' %}#3d3b5e{% else %}#9c484b{% endif %};border-radius:4px;">
            <span style="font-size:20px;font-weight:900;letter-spacing:-0.5px;color:#000000;">{{ person.name }}</span>
            <span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:3px;background:{% if person.state == 'home' %}#3d3b5e{% else %}#9c484b{% endif %};">
              <span style="width:5px;height:5px;border-radius:50%;background:#d0be47;display:inline-block;flex-shrink:0;"></span>
              <span style="font-size:8px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#ffffff;">{% if person.state == 'home' %}Home{% else %}Away{% endif %}</span>
            </span>
          </div>
          {% endfor %}
        </div>
      </div>

      <!-- STATUS: 4 rows, white bg, coloured values -->
      <div style="flex:1;display:flex;flex-direction:column;padding:0 18px;min-height:0;">

        <div style="flex:1;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e0e0e0;">
          <span style="font-size:11px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#333333;">Door</span>
          <span style="font-size:28px;font-weight:900;color:{% if home.door_locked %}#3d3b5e{% else %}#9c484b{% endif %};">{% if home.door_locked %}Locked{% else %}OPEN{% endif %}</span>
        </div>

        <div style="flex:1;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e0e0e0;">
          <span style="font-size:11px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#333333;">Washer</span>
          <span style="font-size:28px;font-weight:900;color:{% if home.washer_running %}#d0be47{% else %}#000000{% endif %};">{% if home.washer_running %}Running{% else %}Off{% endif %}</span>
        </div>

        <div style="flex:1;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e0e0e0;">
          <span style="font-size:11px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#333333;">Lounge Temp</span>
          <span style="font-size:28px;font-weight:900;color:#000000;">{% if home.thermostat_temp %}{{ home.thermostat_temp | round: 1 }}°C{% else %}--{% endif %}</span>
        </div>

        <div style="flex:1;display:flex;align-items:center;justify-content:space-between;">
          <span style="font-size:11px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#333333;">Blinds</span>
          <span style="font-size:28px;font-weight:900;color:{% if home.blinds_open %}#3a5b46{% else %}#000000{% endif %};">{% if home.blind_position == "unavailable" or home.blind_position == nil %}--{% elsif home.blinds_open %}Open{% else %}Closed{% endif %}</span>
        </div>

      </div>
    </div>
  </div>

  <!-- SONOS: solid ochre (playing) or solid terracotta (idle) — full contrast -->
  <div style="height:88px;flex-shrink:0;background:{% if active_sonos %}#d0be47{% else %}#9c484b{% endif %};display:flex;align-items:center;gap:18px;padding:0 22px;border-top:3px solid #000000;">
    <span style="font-size:28px;flex-shrink:0;">{% if active_sonos %}🎵{% else %}🔇{% endif %}</span>
    <div style="flex:1;min-width:0;">
      <div style="font-size:8px;font-weight:900;letter-spacing:4px;text-transform:uppercase;color:{% if active_sonos %}rgba(0,0,0,0.45){% else %}rgba(255,255,255,0.55){% endif %};margin-bottom:4px;">Sonos</div>
      {% if active_sonos %}
        <div style="font-size:22px;font-weight:900;color:#000000;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.1;">{{ active_sonos.title }}</div>
        <div style="font-size:12px;font-weight:700;color:rgba(0,0,0,0.55);margin-top:2px;">{{ active_sonos.artist }}{% if active_sonos.room %} &middot; {{ active_sonos.room }}{% endif %}</div>
      {% else %}
        <div style="font-size:22px;font-weight:900;color:#ffffff;line-height:1.1;">No Music Playing</div>
        <div style="font-size:12px;font-weight:700;color:rgba(255,255,255,0.65);margin-top:2px;">{{ idle_count }} room{% if idle_count != 1 %}s{% endif %} idle</div>
      {% endif %}
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:5px;align-self:center;max-width:200px;justify-content:flex-end;">
      {% for room in sonos %}
        {% if active_sonos %}
          <div style="font-size:8px;font-weight:900;letter-spacing:1px;text-transform:uppercase;padding:4px 9px;border-radius:3px;background:{% if room.state == 'playing' or room.state == 'paused' %}#000000{% else %}rgba(0,0,0,0.15){% endif %};color:{% if room.state == 'playing' or room.state == 'paused' %}#d0be47{% else %}rgba(0,0,0,0.4){% endif %};">{{ room.room | truncate: 10, "" }}</div>
        {% else %}
          <div style="font-size:8px;font-weight:900;letter-spacing:1px;text-transform:uppercase;padding:4px 9px;border-radius:3px;background:{% if room.state == 'playing' or room.state == 'paused' %}#ffffff{% else %}rgba(255,255,255,0.15){% endif %};color:{% if room.state == 'playing' or room.state == 'paused' %}#9c484b{% else %}rgba(255,255,255,0.4){% endif %};">{{ room.room | truncate: 10, "" }}</div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

</div>
