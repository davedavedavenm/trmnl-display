<div style="width:800px; height:470px; background:#000; color:#fff; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; padding:8px; display:flex; box-sizing:border-box; position:relative;">

  <div style="position:absolute; top:8px; right:16px; background:#000; color:#fff; font-size:12px; font-weight:900; letter-spacing:0.15em; text-transform:uppercase; z-index:10;">
    {{ updated_at }}
  </div>

  {% assign active_sonos = sonos | where: "state", "playing" %}
  {% assign is_playing = false %}
  {% if active_sonos.size > 0 %}{% assign is_playing = true %}{% endif %}

  <div style="display:grid; grid-template-columns:1fr 1fr; grid-template-rows:minmax(0, 1fr) minmax(0, 1fr); gap:8px; width:100%; height:100%;">

    {% comment %} FAMILY CARD {% endcomment %}
    <div style="background:#fff; color:#000; border-radius:20px; padding:12px 16px; display:flex; flex-direction:column; justify-content:space-between;">
      <div style="font-size:12px; line-height:1; letter-spacing:0.16em; text-transform:uppercase; font-weight:900; color:#888;">Family</div>
      <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:2px;">
        {% for person in people %}
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div style="font-size:24px; font-weight:900; letter-spacing:-0.02em;">{{ person.name }}</div>
          <div style="display:flex; align-items:center; gap:8px; background:{% if person.state == 'home' %}#00ff00{% else %}#ff0000{% endif %}; padding:4px 10px; border-radius:16px; border:2px solid #000; box-shadow:2px 2px 0 #000;">
            <div style="font-size:12px; font-weight:900; text-transform:uppercase; letter-spacing:0.06em; color:#000;">{{ person.state }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

    {% comment %} WEATHER CARD {% endcomment %}
    <div style="background:#0000ff; color:#fff; border-radius:20px; padding:12px 16px; display:flex; flex-direction:column; justify-content:space-between; position:relative; overflow:hidden;">
      <div style="font-size:12px; line-height:1; letter-spacing:0.16em; text-transform:uppercase; font-weight:900; opacity:0.9;">Weather</div>
      
      <div style="position:absolute; top:-10px; right:-10px; opacity:0.15; pointer-events:none;">
        <svg width="180" height="180" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.5 19C19.985 19 22 16.985 22 14.5C22 12.138 20.19 10.22 17.88 10.02C17.38 7.18 14.93 5 12 5C9.43 5 7.23 6.64 6.32 8.94C3.84 9.27 2 11.39 2 13.88C2 16.7 4.3 19 7.12 19H17.5Z" />
        </svg>
      </div>

      <div style="display:flex; flex-direction:column; justify-content:flex-end; flex:1; padding-bottom:2px; z-index:2;">
        {% if weather and weather.temperature != blank %}
        <div style="display:flex; justify-content:space-between; align-items:flex-end;">
            <div style="display:flex; flex-direction:column;">
                <div style="font-size: {% unless is_playing %}90px{% else %}60px{% endunless %}; line-height:0.85; font-weight:900; letter-spacing:-0.05em; text-shadow:3px 3px 0 #000;">{{ weather.temperature | round }}<span style="font-size:{% unless is_playing %}40px{% else %}30px{% endunless %};">°</span></div>
                <div style="font-size:{% unless is_playing %}30px{% else %}22px{% endunless %}; font-weight:900; text-transform:capitalize; letter-spacing:-0.02em; margin-top:4px;">{{ weather.condition | replace: "-", " " }}</div>
            </div>
            <div style="display:flex; flex-direction:column; gap:4px; align-items:flex-end; padding-bottom:4px;">
                {% if weather.humidity %}
                <div style="font-size:14px; font-weight:800; letter-spacing:0.02em; background:#000; color:#fff; padding:2px 6px; border-radius:4px;">Hum <span style="color:#00ff00;">{{ weather.humidity }}%</span></div>
                {% endif %}
                {% if weather.wind_speed %}
                <div style="font-size:14px; font-weight:800; letter-spacing:0.02em; background:#000; color:#fff; padding:2px 6px; border-radius:4px;">Wind <span style="color:#00ff00;">{{ weather.wind_speed | round }} km/h</span></div>
                {% endif %}
            </div>
        </div>
        {% endif %}
      </div>
    </div>

    {% comment %} MUSIC CARD {% endcomment %}
    {% assign last_active = sonos | where_exp: "s", "s.state == 'playing' or s.state == 'paused'" | first %}
    {% assign is_playing = false %}
    {% if last_active and last_active.state == 'playing' %}{% assign is_playing = true %}{% endif %}
    
    {% if last_active %}
    <div style="background:#ff0000; color:#fff; border-radius:20px; padding:12px 16px; display:flex; flex-direction:column; justify-content:space-between; overflow:hidden; position:relative;">
      <div style="font-size:12px; line-height:1; letter-spacing:0.16em; text-transform:uppercase; font-weight:900; opacity:0.8; position:relative; z-index:2;">{% if is_playing %}Now Playing{% else %}Last Played{% endif %} &middot; <span style="color:#fff;">{{ last_active.room }}</span></div>
      
      <div style="display:flex; justify-content:space-between; align-items:flex-end; position:relative; z-index:2; margin-bottom:0px;">
        <div style="display:flex; flex-direction:column; max-width:66%;">
            {% if last_active.title and last_active.title != blank %}
            <div style="font-size:24px; font-weight:900; letter-spacing:-0.02em; line-height:1.05; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">{{ last_active.title }}</div>
            <div style="font-size:16px; font-weight:800; opacity:0.8; margin-top:4px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ last_active.artist }}</div>
            {% else %}
            <div style="font-size:24px; font-weight:900; letter-spacing:-0.02em; opacity:0.6;">Idle</div>
            {% endif %}
        </div>
        {% if last_active.picture and last_active.picture != blank %}
        <div style="width:70px; height:70px; border-radius:10px; overflow:hidden; border:3px solid #000; flex-shrink:0; background:#000; box-shadow:3px 3px 0 #000;">
            <img src="{{ last_active.picture }}" style="width:100%; height:100%; object-fit:cover;" />
        </div>
        {% else %}
        <div style="width:70px; height:70px; border-radius:10px; overflow:hidden; border:3px solid #000; flex-shrink:0; background:#fff; box-shadow:3px 3px 0 #000; display:flex; align-items:center; justify-content:center;">
           <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle></svg>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {% comment %} HOME STATUS CARD {% endcomment %}
    <div style="background:#ffff00; color:#000; border-radius:20px; padding:12px 16px; display:flex; flex-direction:column; justify-content:space-between; {% unless is_playing %}grid-column: span 1;{% endunless %}">
      <div style="font-size:12px; line-height:1; letter-spacing:0.16em; text-transform:uppercase; font-weight:900; opacity:0.7;">Home Status</div>
      <div style="display:flex; flex-direction:column; gap:{% unless is_playing %}10px{% else %}6px{% endunless %}; margin-bottom:2px;">
        {% if home and home.door_locked != blank %}
        
        <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:2px solid #000; padding-bottom:{% unless is_playing %}6px{% else %}2px{% endunless %};">
          <div style="display:flex; align-items:center; gap:8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C9.24 2 7 4.24 7 7V10H6C4.9 10 4 12V20C4 21.1 4.9 22 6 22H18C19.1 22 20 21.1 20 20V12C20 10.9 19.1 10 18 10H17V7C17 4.24 14.76 2 12 2ZM12 4C13.66 4 15 5.34 15 7V10H9V7C9 5.34 10.34 4 12 4ZM12 14C13.1 14 14 14.9 14 16C14 17.1 13.1 18 12 18C10.9 18 10 17.1 10 16C10 14.9 10.9 14 12 14Z"/>
            </svg>
            <div style="font-size:18px; font-weight:900; letter-spacing:-0.01em;">Front Door</div>
          </div>
          <div style="display:flex; align-items:center; gap:6px;">
            <div style="font-size:14px; font-weight:900;">{% if home.door_locked %}Locked{% else %}Unlocked{% endif %}</div>
            <div style="width:14px; height:14px; border-radius:50%; background:{% if home.door_locked %}#00ff00{% else %}#ff0000{% endif %}; border: 2px solid #000;"></div>
          </div>
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:2px solid #000; padding-bottom:{% unless is_playing %}6px{% else %}2px{% endunless %};">
          <div style="display:flex; align-items:center; gap:8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19 4H5C3.9 4 3 4.9 3 6V18C3 19.1 3.9 20 5 20H19C20.1 20 21 19.1 21 18V6C21 4.9 20.1 4 19 4ZM12 17C9.79 17 8 15.21 8 13C8 10.79 9.79 9 12 9C14.21 9 16 10.79 16 13C16 15.21 14.21 17 12 17ZM7 7H5V5H7V7Z"/>
            </svg>
            <div style="font-size:18px; font-weight:900; letter-spacing:-0.01em;">Laundry</div>
          </div>
          <div style="display:flex; align-items:center; gap:6px;">
            <div style="font-size:14px; font-weight:900;">{% if home.washer_running %}Running{% else %}Idle{% endif %}</div>
            <div style="width:14px; height:14px; border-radius:50%; background:{% if home.washer_running %}#ff8800{% else %}#00ff00{% endif %}; border: 2px solid #000;"></div>
          </div>
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:2px solid #000; padding-bottom:{% unless is_playing %}6px{% else %}2px{% endunless %};">
          <div style="display:flex; align-items:center; gap:8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 19V3H4V19H2V21H22V19H20ZM14 9H10V11H14V9ZM14 13H10V15H14V13Z"/>
            </svg>
            <div style="font-size:18px; font-weight:900; letter-spacing:-0.01em;">Blinds</div>
          </div>
          <div style="font-size:14px; font-weight:900; background:#000; color:#ffff00; padding:2px 6px; border-radius:4px;">{% if home.blind_position == "0" %}Closed{% else %}Open {{ home.blind_position }}%{% endif %}</div>
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div style="display:flex; align-items:center; gap:8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M15 13V5C15 3.34 13.66 2 12 2C10.34 2 9 3.34 9 5V13C7.22 14.28 6 16.48 6 19C6 22.31 8.69 25 12 25C15.31 25 18 22.31 18 19C18 16.48 16.78 14.28 15 13ZM12 21C10.9 21 10 20.1 10 19C10 17.9 10.9 17 12 17C13.1 17 14 17.9 14 19C14 20.1 13.1 21 12 21ZM13 13.88V5C13 4.45 12.55 4 12 4C11.45 4 11 4.45 11 5V13.88C11.83 14.25 12.5 15.04 12.5 16H11.5C11.5 15.04 12.17 14.25 13 13.88Z"/>
            </svg>
            <div style="font-size:18px; font-weight:900; letter-spacing:-0.01em;">Thermostat</div>
          </div>
          <div style="font-size:14px; font-weight:900; background:#000; color:#ffff00; padding:2px 6px; border-radius:4px;">{% if home.thermostat_temp %}{{ home.thermostat_temp | round: 1 }}°C{% else %}--{% endif %}</div>
        </div>

        {% endif %}
      </div>
    </div>

  </div>
</div>