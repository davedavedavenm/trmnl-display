{% assign theme_mode = trmnl.plugin_settings.custom_fields_values.theme | default: 'dark' %}
{% assign show_album = trmnl.plugin_settings.custom_fields_values.show_album | default: true %}
{% assign show_album_art = trmnl.plugin_settings.custom_fields_values.show_album_art | default: true %}
{% assign show_next_tracks = trmnl.plugin_settings.custom_fields_values.show_next_tracks | default: true %}
{% if theme_mode == 'light' %}
  {% assign bg = '#f6f1e8' %}
  {% assign fg = '#141414' %}
  {% assign soft = '#6f6558' %}
  {% assign panel = '#fffdfa' %}
  {% assign border = '#d5ccbf' %}
{% else %}
  {% assign bg = '#111111' %}
  {% assign fg = '#fffdf8' %}
  {% assign soft = '#d8c9a2' %}
  {% assign panel = '#1a1a1a' %}
  {% assign border = '#3b352d' %}
{% endif %}
<div class="layout layout--col h--full w--full" style="padding:12px 18px 10px; background:{{ bg }}; color:{{ fg }}; overflow:hidden;">
  <div style="display:grid; grid-template-columns: 1fr auto; gap:14px; align-items:end; border-bottom:2px solid {{ fg }}; padding-bottom:8px; margin-bottom:10px;">
    <div style="display:flex; flex-direction:column; gap:4px;">
      <div style="font-size:11px; line-height:1; letter-spacing:0.18em; text-transform:uppercase; color:{{ soft }}; font-weight:800;">{{ room_name }}</div>
      <div style="font-size:32px; line-height:0.9; letter-spacing:-0.05em; font-weight:900; color:{{ fg }};">{% if state == 'PLAYING' %}Now Playing{% else %}Recently Played{% endif %}</div>
    </div>
    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:4px;">
      <div style="font-size:12px; line-height:1; letter-spacing:0.18em; text-transform:uppercase; color:{{ soft }}; font-weight:900;">{{ state }}</div>
      <div style="font-size:10px; line-height:1.2; letter-spacing:0.12em; text-transform:uppercase; color:{{ soft }}; font-weight:800; text-align:right;">Updated {{ updated_at }}</div>
    </div>
  </div>

  <div style="display:grid; grid-template-columns:{% if show_album_art == true or show_album_art == 'true' %}250px minmax(0, 1fr){% else %}1fr{% endif %}; gap:20px; flex:1; align-items:start; min-height:0;">
    {% if show_album_art == true or show_album_art == 'true' %}
    <div style="height:250px; border:1px solid {{ border }}; border-radius:24px; overflow:hidden; background:{{ panel }}; display:flex; align-items:center; justify-content:center; box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);">
      {% if album_art_url %}
      <img class="image" src="{{ album_art_url }}" style="width:100%; height:100%; object-fit:cover;">
      {% else %}
      <div style="font-size:14px; text-transform:uppercase; letter-spacing:0.12em; color:{{ soft }}; font-weight:800;">No Art</div>
      {% endif %}
    </div>
    {% endif %}
    <div style="display:flex; flex-direction:column; justify-content:flex-start; gap:10px; min-width:0; padding-top:2px; min-height:0;">
      <div style="font-size:46px; line-height:0.9; letter-spacing:-0.055em; font-weight:900; color:{{ fg }};">{{ title | default: 'Nothing Playing' }}</div>
      <div style="font-size:24px; line-height:1; letter-spacing:-0.025em; font-weight:800; color:{{ soft }};">{{ artist | default: 'Unknown Artist' }}</div>
      {% if show_album == true or show_album == 'true' %}
      <div style="font-size:13px; line-height:1.2; text-transform:uppercase; letter-spacing:0.12em; color:{{ soft }}; font-weight:800;">{{ album }}</div>
      {% endif %}

      {% if group_size and group_size > 1 %}
      <div style="font-size:11px; line-height:1.2; text-transform:uppercase; letter-spacing:0.1em; color:{{ soft }}; font-weight:800;">Grouped: {{ group_rooms | join: ', ' }}</div>
      {% endif %}
      {% if same_content_rooms and same_content_rooms.size > 0 %}
      <div style="font-size:11px; line-height:1.2; text-transform:uppercase; letter-spacing:0.1em; color:{{ soft }}; font-weight:800;">Also playing in: {{ same_content_rooms | join: ', ' }}</div>
      {% elsif multiple_active == true or multiple_active == 'true' %}
      <div style="font-size:11px; line-height:1.2; text-transform:uppercase; letter-spacing:0.1em; color:{{ soft }}; font-weight:800;">Other active rooms: {{ other_active_rooms | join: ', ' }}</div>
      {% endif %}

      <div style="display:grid; grid-template-columns:{% if group_size and group_size > 1 or same_content_rooms and same_content_rooms.size > 0 or multiple_active == true or multiple_active == 'true' %} repeat(2, minmax(0, 1fr)) {% else %}1fr{% endif %}; gap:8px 12px; padding-top:6px; max-width:520px;">
        <div style="display:flex; flex-direction:column; gap:3px; padding:12px 14px; border:1px solid {{ border }}; border-radius:18px; background:{{ panel }};">
          <div style="font-size:10px; line-height:1; text-transform:uppercase; letter-spacing:0.12em; color:{{ soft }}; font-weight:800;">Source</div>
          <div style="font-size:18px; line-height:1; letter-spacing:-0.02em; font-weight:800; color:{{ fg }};">{{ source | default: 'Unknown' }}</div>
        </div>
        {% if group_size and group_size > 1 or same_content_rooms and same_content_rooms.size > 0 or multiple_active == true or multiple_active == 'true' %}
        <div style="display:flex; flex-direction:column; gap:3px; padding:12px 14px; border:1px solid {{ border }}; border-radius:18px; background:{{ panel }};">
          <div style="font-size:10px; line-height:1; text-transform:uppercase; letter-spacing:0.12em; color:{{ soft }}; font-weight:800;">Rooms</div>
          <div style="font-size:16px; line-height:1.15; letter-spacing:-0.02em; font-weight:800; color:{{ fg }};">
            {% if same_content_rooms and same_content_rooms.size > 0 %}
              Also: {{ same_content_rooms | join: ', ' }}
            {% elsif multiple_active == true or multiple_active == 'true' %}
              Active: {{ other_active_rooms | join: ', ' }}
            {% else %}
              {{ group_rooms | join: ', ' }}
            {% endif %}
          </div>
        </div>
        {% endif %}
      </div>

      {% if (show_next_tracks == true or show_next_tracks == 'true') and next_tracks and next_tracks.size > 0 %}
      <div style="padding-top:8px; display:flex; flex-direction:column; gap:6px; max-width:560px; min-height:0;">
        <div style="font-size:10px; line-height:1; text-transform:uppercase; letter-spacing:0.14em; color:{{ soft }}; font-weight:900;">Up Next</div>
        {% for item in next_tracks limit:3 %}
        <div style="display:grid; grid-template-columns:20px minmax(0, 1fr); gap:8px; align-items:start; padding:6px 0; border-top:1px solid {{ border }};">
          <div style="font-size:16px; line-height:1; font-weight:900; color:{{ soft }};">{{ forloop.index }}</div>
          <div style="display:flex; flex-direction:column; gap:2px; min-width:0;">
            <div style="font-size:16px; line-height:0.95; letter-spacing:-0.02em; font-weight:900; color:{{ fg }};">{{ item.title }}</div>
            {% if item.artist %}
            <div style="font-size:10px; line-height:1; text-transform:uppercase; letter-spacing:0.08em; color:{{ soft }}; font-weight:800;">{{ item.artist }}</div>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</div>
