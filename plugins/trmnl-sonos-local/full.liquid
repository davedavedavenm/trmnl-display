{% assign theme_mode = trmnl.plugin_settings.custom_fields_values.theme | default: 'dark' %}
{% assign album_art_mode = trmnl.plugin_settings.custom_fields_values.album_art_mode | default: 'raw' %}
{% assign show_album = trmnl.plugin_settings.custom_fields_values.show_album | default: true %}
{% assign show_album_art = trmnl.plugin_settings.custom_fields_values.show_album_art | default: true %}
{% assign show_next_tracks = trmnl.plugin_settings.custom_fields_values.show_next_tracks | default: true %}
{% if theme_mode == 'light' %}
  {% assign bg = '#f6f1e8' %}
  {% assign fg = '#141414' %}
  {% assign soft = '#6f6558' %}
  {% assign accent = '#FF0000' %}
  {% assign accent_soft = '#FFA500' %}
  {% assign accent_alt = '#FFFF00' %}
  {% assign accent_cool = '#0000FF' %}
{% else %}
  {% assign bg = '#111111' %}
  {% assign fg = '#fffdf8' %}
  {% assign soft = '#d8c9a2' %}
  {% assign accent = '#FF0000' %}
  {% assign accent_soft = '#FFA500' %}
  {% assign accent_alt = '#FFFF00' %}
  {% assign accent_cool = '#0000FF' %}
{% endif %}
<div class="layout layout--col h--full w--full" style="padding:10px 16px 10px; background:{{ bg }}; color:{{ fg }}; overflow:hidden;">
  <div style="display:grid; grid-template-columns: 1fr auto; gap:14px; align-items:end; border-bottom:2px solid {{ fg }}; padding-bottom:8px; margin-bottom:10px;">
    <div style="display:flex; flex-direction:column; gap:4px;">
      <div style="display:inline-flex; align-self:flex-start; padding:5px 10px; border-radius:999px; background:{{ accent_soft }}; color:#000000; font-size:11px; line-height:1; letter-spacing:0.18em; text-transform:uppercase; font-weight:900;">{{ room_name }}</div>
      <div style="font-size:30px; line-height:0.92; letter-spacing:-0.05em; font-weight:900; color:{{ fg }};">{% if state == 'PLAYING' %}Now Playing{% else %}Recently Played{% endif %}</div>
    </div>
    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:4px;">
      <div style="padding:5px 10px; border-radius:999px; background:{{ accent_alt }}; color:#000000; font-size:12px; line-height:1; letter-spacing:0.18em; text-transform:uppercase; font-weight:900;">{{ state }}</div>
      <div style="font-size:10px; line-height:1.2; letter-spacing:0.12em; text-transform:uppercase; color:{{ soft }}; font-weight:800; text-align:right;">Updated {{ updated_at }}</div>
    </div>
  </div>

  <div style="display:grid; grid-template-columns:{% if show_album_art == true or show_album_art == 'true' %}230px minmax(0, 1fr){% else %}1fr{% endif %}; gap:18px; flex:1; align-items:start; min-height:0;">
    {% if show_album_art == true or show_album_art == 'true' %}
    <div style="height:230px; border:none; border-radius:22px; overflow:hidden; background:transparent; display:flex; align-items:center; justify-content:center; box-shadow:none;">
      {% if album_art_mode == 'mono' and album_art_mono_data_uri %}
      <img class="image" src="{{ album_art_mono_data_uri }}" style="width:100%; height:100%; object-fit:cover;">
      {% elsif album_art_mode == 'balanced' and album_art_balanced_data_uri %}
      <img class="image" src="{{ album_art_balanced_data_uri }}" style="width:100%; height:100%; object-fit:cover;">
      {% elsif album_art_mode == 'raw' and album_art_url %}
      <img class="image" src="{{ album_art_url }}" style="width:100%; height:100%; object-fit:cover;">
      {% elsif album_art_vivid_data_uri %}
      <img class="image" src="{{ album_art_vivid_data_uri }}" style="width:100%; height:100%; object-fit:cover;">
      {% elsif album_art_balanced_data_uri %}
      <img class="image" src="{{ album_art_balanced_data_uri }}" style="width:100%; height:100%; object-fit:cover;">
      {% elsif album_art_data_uri %}
      <img class="image" src="{{ album_art_data_uri }}" style="width:100%; height:100%; object-fit:cover;">
      {% elsif album_art_url %}
      <img class="image" src="{{ album_art_url }}" style="width:100%; height:100%; object-fit:cover;">
      {% else %}
      <div style="width:100%; height:100%; display:grid; grid-template-rows:1fr 1fr; border-radius:22px; overflow:hidden;">
        <div style="display:flex; align-items:center; justify-content:center; background:{{ accent }}; color:#FFFFFF; font-size:22px; line-height:1; letter-spacing:0.14em; text-transform:uppercase; font-weight:900;">Sonos</div>
        <div style="display:flex; align-items:center; justify-content:center; background:{{ accent_cool }}; color:#FFFFFF; font-size:18px; line-height:1; letter-spacing:0.12em; text-transform:uppercase; font-weight:900;">No Art</div>
      </div>
      {% endif %}
    </div>
    {% endif %}
    <div style="display:flex; flex-direction:column; justify-content:flex-start; gap:8px; min-width:0; padding-top:0; min-height:0;">
      <div style="font-size:40px; line-height:0.92; letter-spacing:-0.05em; font-weight:900; color:{{ fg }};">{{ title | default: 'Nothing Playing' }}</div>
      <div style="font-size:22px; line-height:1; letter-spacing:-0.02em; font-weight:800; color:{{ soft }};">{{ artist | default: 'Unknown Artist' }}</div>
      {% if show_album == true or show_album == 'true' %}
      <div style="font-size:13px; line-height:1.2; text-transform:uppercase; letter-spacing:0.12em; color:{{ soft }}; font-weight:800;">{{ album }}</div>
      {% endif %}

      {% if group_size and group_size > 1 %}
      <div style="font-size:11px; line-height:1.2; text-transform:uppercase; letter-spacing:0.1em; color:{{ soft }}; font-weight:800;">Grouped: {{ group_rooms | join: ', ' }}</div>
      {% endif %}
      {% if same_content_rooms and same_content_rooms.size > 0 %}
      <div style="font-size:11px; line-height:1.2; text-transform:uppercase; letter-spacing:0.1em; color:{{ soft }}; font-weight:800;">Also playing in: {{ same_content_rooms | join: ', ' }}</div>
      {% elsif multiple_active == true or multiple_active == 'true' %}
      <div style="font-size:11px; line-height:1.2; text-transform:uppercase; letter-spacing:0.1em; color:{{ soft }}; font-weight:800;">Other active rooms: {{ other_active_rooms | join: ', ' }}</div>
      {% endif %}

      <div style="display:grid; grid-template-columns:{% if group_size and group_size > 1 or same_content_rooms and same_content_rooms.size > 0 or multiple_active == true or multiple_active == 'true' %} repeat(2, minmax(0, 1fr)) {% else %}1fr{% endif %}; gap:8px 12px; padding-top:4px; max-width:520px;">
        <div style="display:flex; flex-direction:column; gap:3px; padding:12px 14px; border:none; border-radius:18px; background:{{ accent_soft }};">
          <div style="font-size:10px; line-height:1; text-transform:uppercase; letter-spacing:0.12em; color:#000000; font-weight:900;">Source</div>
          <div style="font-size:18px; line-height:1; letter-spacing:-0.02em; font-weight:900; color:#000000;">{{ source | default: 'Unknown' }}</div>
        </div>
        {% if group_size and group_size > 1 or same_content_rooms and same_content_rooms.size > 0 or multiple_active == true or multiple_active == 'true' %}
        <div style="display:flex; flex-direction:column; gap:3px; padding:12px 14px; border:none; border-radius:18px; background:{{ accent_cool }};">
          <div style="font-size:10px; line-height:1; text-transform:uppercase; letter-spacing:0.12em; color:#FFFFFF; font-weight:900;">Rooms</div>
          <div style="font-size:16px; line-height:1.15; letter-spacing:-0.02em; font-weight:900; color:#FFFFFF;">
            {% if same_content_rooms and same_content_rooms.size > 0 %}
              Also: {{ same_content_rooms | join: ', ' }}
            {% elsif multiple_active == true or multiple_active == 'true' %}
              Active: {{ other_active_rooms | join: ', ' }}
            {% else %}
              {{ group_rooms | join: ', ' }}
            {% endif %}
          </div>
        </div>
        {% endif %}
      </div>

      {% assign next_tracks_enabled = false %}
      {% if show_next_tracks == true or show_next_tracks == 'true' %}
        {% assign next_tracks_enabled = true %}
      {% endif %}
      {% if next_tracks_enabled and next_tracks and next_tracks.size > 0 %}
      <div style="padding-top:6px; display:flex; flex-direction:column; gap:5px; max-width:560px; min-height:0;">
        <div style="display:inline-flex; align-self:flex-start; padding:4px 10px; border-radius:999px; background:{{ accent }}; color:#FFFFFF; font-size:10px; line-height:1; text-transform:uppercase; letter-spacing:0.14em; font-weight:900;">Up Next</div>
        {% for item in next_tracks limit:3 %}
        <div style="display:grid; grid-template-columns:20px minmax(0, 1fr); gap:8px; align-items:start; padding:6px 0; border-top:1px solid {{ fg }};">
          <div style="font-size:16px; line-height:1; font-weight:900; color:{{ accent_soft }};">{{ forloop.index }}</div>
          <div style="display:flex; flex-direction:column; gap:2px; min-width:0;">
            <div style="font-size:16px; line-height:0.95; letter-spacing:-0.02em; font-weight:900; color:{{ fg }};">{{ item.title }}</div>
            {% if item.artist %}
            <div style="font-size:10px; line-height:1; text-transform:uppercase; letter-spacing:0.08em; color:{{ soft }}; font-weight:800;">{{ item.artist }}</div>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</div>
