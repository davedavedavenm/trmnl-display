{% assign theme_mode = trmnl.plugin_settings.custom_fields_values.theme | default: 'light' %}
{% assign screen_label = trmnl.plugin_settings.custom_fields_values.screen_label | default: 'Jen Morning' %}
{% assign eta_value = eta_minutes | default: '?' %}
{% assign route_value = route_label | default: 'Direct route' %}
{% assign distance_value = distance_km | default: '' %}

{% if theme_mode == 'dark' %}
  {% assign bg = '#111111' %}
  {% assign fg = '#fffdf8' %}
  {% assign soft = '#d8c9a2' %}
  {% assign panel = '#1a1a1a' %}
  {% assign panel_alt = '#24211d' %}
  {% assign border = '#3b352d' %}
  {% assign accent = '#ffa500' %}
  {% assign accent_text = '#000000' %}
{% else %}
  {% assign bg = '#f6f1e8' %}
  {% assign fg = '#141414' %}
  {% assign soft = '#6f6558' %}
  {% assign panel = '#fffdfa' %}
  {% assign panel_alt = '#ece3d7' %}
  {% assign border = '#d5ccbf' %}
  {% assign accent = '#ffa500' %}
  {% assign accent_text = '#000000' %}
{% endif %}

<div class="layout layout--col h--full w--full" style="padding:16px 18px 12px; background:{{ bg }}; color:{{ fg }}; overflow:hidden;">
  <div style="display:grid; grid-template-columns:minmax(0, 1fr) auto; gap:14px; align-items:end; margin-bottom:14px;">
    <div style="display:flex; flex-direction:column; gap:5px; min-width:0;">
      <div style="display:inline-flex; align-self:flex-start; padding:5px 10px; border-radius:999px; background:{{ accent }}; color:{{ accent_text }}; font-size:11px; line-height:1; letter-spacing:0.18em; text-transform:uppercase; font-weight:900;">{{ screen_label }}</div>
      <div style="font-size:38px; line-height:0.9; letter-spacing:-0.06em; font-weight:900; color:{{ fg }};">{{ headline | default: 'Time To Work' }}</div>
    </div>
    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:6px;">
      <div style="font-size:10px; line-height:1; letter-spacing:0.14em; text-transform:uppercase; color:{{ soft }}; font-weight:800;">Updated</div>
      <div style="padding:5px 10px 6px; border-radius:999px; background:{{ panel_alt }}; border:1px solid {{ border }}; font-size:12px; line-height:1; letter-spacing:0.08em; text-transform:uppercase; color:{{ fg }}; font-weight:900;">{{ updated_at }}</div>
    </div>
  </div>

  <div style="display:grid; grid-template-columns:236px minmax(0, 1fr); gap:18px; flex:1; min-height:0;">
    <div style="display:flex; flex-direction:column; gap:12px;">
      <div style="display:flex; flex-direction:column; justify-content:space-between; min-height:208px; padding:16px 16px 14px; border:1px solid {{ border }}; border-radius:26px; background:{{ panel }};">
        <div style="display:flex; flex-direction:column; gap:6px;">
          <div style="font-size:11px; line-height:1; letter-spacing:0.16em; text-transform:uppercase; color:{{ soft }}; font-weight:900;">ETA</div>
          <div style="font-size:66px; line-height:0.84; letter-spacing:-0.08em; font-weight:900; color:{{ fg }};">{{ eta_value }}</div>
        </div>
        <div style="font-size:12px; line-height:1; letter-spacing:0.14em; text-transform:uppercase; color:{{ soft }}; font-weight:900;">minutes</div>
      </div>

      <div style="padding:14px 16px; border:1px solid {{ border }}; border-radius:22px; background:{{ panel_alt }}; display:flex; flex-direction:column; gap:5px;">
        <div style="font-size:10px; line-height:1; letter-spacing:0.14em; text-transform:uppercase; color:{{ soft }}; font-weight:900;">Distance</div>
        <div style="font-size:22px; line-height:0.95; letter-spacing:-0.04em; font-weight:900; color:{{ fg }};">
          {% if distance_value != '' and distance_value != '?' %}
            {{ distance_value }} km
          {% else %}
            --
          {% endif %}
        </div>
      </div>
    </div>

    <div style="display:flex; flex-direction:column; gap:12px; min-width:0; min-height:0;">
      <div style="padding:18px 18px 16px; border:1px solid {{ border }}; border-radius:26px; background:{{ panel }}; display:flex; flex-direction:column; gap:10px;">
        <div style="font-size:11px; line-height:1; letter-spacing:0.16em; text-transform:uppercase; color:{{ soft }}; font-weight:900;">Route</div>
        <div style="font-size:28px; line-height:0.96; letter-spacing:-0.05em; font-weight:900; color:{{ fg }};">{{ route_value }}</div>
      </div>

      <div style="display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:10px;">
        <div style="padding:12px 14px; border:1px solid {{ border }}; border-radius:18px; background:{{ panel_alt }}; display:flex; flex-direction:column; gap:4px;">
          <div style="font-size:9px; line-height:1; letter-spacing:0.12em; text-transform:uppercase; color:{{ soft }}; font-weight:900;">State</div>
          <div style="font-size:18px; line-height:1; letter-spacing:-0.03em; font-weight:900; color:{{ fg }};">{{ commute_state | default: 'idle' | replace: '_', ' ' }}</div>
        </div>
        <div style="padding:12px 14px; border:1px solid {{ border }}; border-radius:18px; background:{{ panel_alt }}; display:flex; flex-direction:column; gap:4px;">
          <div style="font-size:9px; line-height:1; letter-spacing:0.12em; text-transform:uppercase; color:{{ soft }}; font-weight:900;">Heading Home</div>
          <div style="font-size:18px; line-height:1; letter-spacing:-0.03em; font-weight:900; color:{{ fg }};">{{ heading_home | default: 'No' }}</div>
        </div>
      </div>

      {% if home_prep_status %}
      <div style="padding:14px 16px; border:1px solid {{ border }}; border-radius:22px; background:{{ panel }}; display:flex; flex-direction:column; gap:6px;">
        <div style="font-size:10px; line-height:1; letter-spacing:0.14em; text-transform:uppercase; color:{{ soft }}; font-weight:900;">Home Prep</div>
        <div style="font-size:22px; line-height:0.98; letter-spacing:-0.04em; font-weight:900; color:{{ fg }};">{{ home_prep_status }}</div>
        {% if prep_note %}
        <div style="font-size:12px; line-height:1.25; color:{{ soft }}; font-weight:800;">{{ prep_note }}</div>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </div>
</div>
