{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "UK Bus Departures (TransportAPI)",
  "required": ["app_id", "app_key", "atco"],
  "properties": {
    "atco": {
      "type": "string",
      "title": "ATCO Stop Code",
      "description": "ATCO code for the bus stop (e.g. 0100BRP90003)",
      "default": "0100BRP90003"
    },
    "timespan": {
      "type": "string",
      "title": "Timespan (hours)",
      "description": "How far ahead to fetch departures",
      "default": "2",
      "enum": ["1", "2", "3", "4"]
    },
    "app_id": {
      "type": "string",
      "title": "TransportAPI App ID",
      "description": "TransportAPI application ID",
      "ui:widget": "password"
    },
    "app_key": {
      "type": "string",
      "title": "TransportAPI API Key",
      "description": "TransportAPI API key",
      "ui:widget": "password"
    },
    "stop_name": {
      "type": "string",
      "title": "Stop Display Name",
      "description": "Friendly stop name for the colour display",
      "default": "Bus Stop"
    }
  }
}
