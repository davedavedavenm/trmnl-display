# Example environment for /home/dave/.env.trmnl-ha-dashboard on khpi5.
# Keep live HA_TOKEN and TRMNL_WEBHOOK_URL out of git.

HA_URL=http://192.168.1.89:8123
HA_TOKEN=
TRMNL_WEBHOOK_URL=

TRMNL_DASHBOARD_TITLE=Home Assistant
TRMNL_INSTANCE_LABEL=Home
TRMNL_LAYOUT_VARIANT=compact_grid
TRMNL_COLOUR_PROFILE=inky_spectra_7
TRMNL_UPDATED_AT_FORMAT=%d %b %H:%M
TRMNL_CACHE_FILE=/home/dave/.trmnl_ha_cache.json

# Optional: when set to 1, slot and generic-entity settings are read from
# Home Assistant helpers defined in config/packages/trmnl_ha_dashboard.yaml.
TRMNL_HA_MANAGED_CONFIG=0

TRMNL_WEATHER_ENTITY=weather.forecast_home
TRMNL_PERSON_ENTITIES=person.alex,person.sam
TRMNL_SONOS_ENTITIES=media_player.living_room,media_player.kitchen
TRMNL_SONOS_LABEL=Sonos
TRMNL_LIGHT_ENTITIES=light.living_room,light.bedroom,light.kitchen
TRMNL_LIGHT_LABELS=Living,Bedroom,Kitchen
TRMNL_DOOR_ENTITY=binary_sensor.front_door_locked
TRMNL_DOOR_LABEL=Front door
TRMNL_DOOR_DETAIL_LABEL=Security
TRMNL_WASHER_ENTITY=binary_sensor.washer_running
TRMNL_WASHER_LABEL=Washer
TRMNL_WASHER_DETAIL_LABEL=Utility
TRMNL_BLIND_ENTITY=cover.living_room_blinds
TRMNL_BLIND_LABEL=Blinds
TRMNL_BLIND_DETAIL_LABEL=Position
TRMNL_BLIND_OPEN_POSITION=100
TRMNL_THERMOSTAT_ENTITY=climate.thermostat
TRMNL_THERMOSTAT_LABEL=Climate
TRMNL_THERMOSTAT_DETAIL_LABEL=Indoor
TRMNL_PEOPLE_LABEL=People
TRMNL_MEDIA_LABEL=Media
TRMNL_GENERIC_ENTITIES=
TRMNL_GENERIC_LABELS=
TRMNL_GENERIC_ICONS=
TRMNL_GENERIC_STATUS_COLOURS=

# Fixed card slot intent. Supported types:
# weather, indoor, door_lock, cover, washer, light_group, person_group, media, generic_entity, hidden.
TRMNL_TOP_LEFT_CARD_TYPE=weather
TRMNL_TOP_LEFT_ENTITY=
TRMNL_TOP_LEFT_LABEL=
TRMNL_TOP_LEFT_DETAIL_LABEL=
TRMNL_TOP_RIGHT_CARD_TYPE=indoor
TRMNL_TOP_RIGHT_ENTITY=
TRMNL_TOP_RIGHT_LABEL=
TRMNL_TOP_RIGHT_DETAIL_LABEL=
TRMNL_STATUS_1_CARD_TYPE=door_lock
TRMNL_STATUS_1_ENTITY=
TRMNL_STATUS_1_LABEL=Front door
TRMNL_STATUS_1_DETAIL_LABEL=Security
TRMNL_STATUS_2_CARD_TYPE=cover
TRMNL_STATUS_2_ENTITY=
TRMNL_STATUS_2_LABEL=Blinds
TRMNL_STATUS_2_DETAIL_LABEL=Position
TRMNL_STATUS_3_CARD_TYPE=washer
TRMNL_STATUS_3_ENTITY=
TRMNL_STATUS_3_LABEL=Washer
TRMNL_STATUS_3_DETAIL_LABEL=Utility
TRMNL_BOTTOM_LEFT_CARD_TYPE=person_group
TRMNL_BOTTOM_LEFT_ENTITY=
TRMNL_BOTTOM_LEFT_LABEL=People
TRMNL_BOTTOM_LEFT_DETAIL_LABEL=
TRMNL_BOTTOM_RIGHT_CARD_TYPE=media
TRMNL_BOTTOM_RIGHT_ENTITY=
TRMNL_BOTTOM_RIGHT_LABEL=Media
TRMNL_BOTTOM_RIGHT_DETAIL_LABEL=Sonos

# Optional: write the exact webhook payload to disk for the colour sidecar renderer.
TRMNL_SIDECAR_PAYLOAD_PATH=/home/dave/trmnl-ha-dashboard-payload.json

# Optional live LaraPaper handoff settings used by the playlist-safe
# trmnl-update-ha-sidecar-image script and by manual ha_dashboard mode activation.
TRMNL_SIDECAR_HANDOFF_ENABLED=1
TRMNL_SIDECAR_IMAGE_PATH=/home/dave/sidecar_colour_dashboard_next.png
TRMNL_SIDECAR_IMAGE_NAME=sidecar_colour_dashboard_next
TRMNL_LARAPAPER_CONTAINER=larapaper-app-1
TRMNL_DEVICE_ID=1
TRMNL_MODE_PLUGIN_HA_DASHBOARD=Home Assistant
