# Example environment for /home/dave/.env.trmnl-ha-dashboard on khpi5.
# Keep live HA_TOKEN and TRMNL_WEBHOOK_URL out of git.

HA_URL=http://192.168.1.89:8123
HA_TOKEN=
TRMNL_WEBHOOK_URL=

TRMNL_DASHBOARD_TITLE=Home Assistant
TRMNL_INSTANCE_LABEL=Home
TRMNL_LAYOUT_VARIANT=compact_grid
TRMNL_COLOUR_PROFILE=inky_spectra_7
TRMNL_UPDATED_AT_FORMAT=%d %b %H:%M
TRMNL_CACHE_FILE=/home/dave/.trmnl_ha_cache.json

TRMNL_WEATHER_ENTITY=weather.forecast_home
TRMNL_PERSON_ENTITIES=person.alex,person.sam
TRMNL_SONOS_ENTITIES=media_player.living_room,media_player.kitchen
TRMNL_LIGHT_ENTITIES=light.living_room,light.bedroom,light.kitchen
TRMNL_DOOR_ENTITY=binary_sensor.front_door_locked
TRMNL_WASHER_ENTITY=binary_sensor.washer_running
TRMNL_BLIND_ENTITY=cover.living_room_blinds
TRMNL_BLIND_OPEN_POSITION=100
TRMNL_THERMOSTAT_ENTITY=climate.thermostat
TRMNL_ENERGY_ENTITY=sensor.daily_energy

# Optional: write the exact webhook payload to disk for the colour sidecar renderer.
TRMNL_SIDECAR_PAYLOAD_PATH=/home/dave/trmnl-ha-dashboard-payload.json
