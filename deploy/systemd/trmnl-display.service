# /etc/systemd/system/trmnl-display.service
[Unit]
Description=TRMNL Display Client
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=dave
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/home/dave/bin/trmnl-display-shell.sh
Restart=always
RestartSec=15

[Install]
WantedBy=multi-user.target
